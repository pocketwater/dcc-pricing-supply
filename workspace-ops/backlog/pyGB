import time
import re
from urllib.parse import quote_plus
from selenium import webdriver
from selenium.common.exceptions import TimeoutException
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

SEARCH_TERMS = [
    "Yakima, WA",
    "Ponderay, ID",
    "Wenatchee, WA",
]

FUEL_TYPES = {
    "Regular": 1,
    "Premium": 3,
    "Diesel": 4,
}

options = Options()
options.add_argument("--headless=new")
options.add_argument("--no-sandbox")
options.add_argument("--disable-dev-shm-usage")
options.add_argument("--disable-gpu")
options.add_argument("--window-size=1280,900")
options.add_argument(
    "user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
    "AppleWebKit/537.36 (KHTML, like Gecko) "
    "Chrome/124.0.0.0 Safari/537.36"
)

print("Fetching gas prices by city/state...")
driver = webdriver.Chrome(options=options)
wait = WebDriverWait(driver, 20)

STAR_JUNK = re.compile(
    r'(Full Star Icon|Half-filled Star Icon|Empty Star Icon)', re.IGNORECASE
)
AGE_RE = re.compile(
    r"(Just now|Today|Yesterday|\d+\s+(?:Minute|Hour|Day|Week|Month)s?\s+Ago)",
    re.IGNORECASE,
)

CARD_XPATH = (
    "//div[contains(@class,'GenericStationListItem-module__station') "
    "and not(ancestor::div[contains(@class,'GenericStationListItem-module__station')])]"
)


def collect_station_cards(driver, max_scrolls=20, pause_seconds=1.0):
    """Scroll result list to trigger lazy-loading and return all station cards."""
    stable_rounds = 0
    last_count = -1

    for _ in range(max_scrolls):
        cards = driver.find_elements(By.XPATH, CARD_XPATH)
        current_count = len(cards)

        if current_count == last_count:
            stable_rounds += 1
        else:
            stable_rounds = 0
            last_count = current_count

        if stable_rounds >= 2:
            break

        driver.execute_script("window.scrollBy(0, Math.floor(window.innerHeight * 0.9));")
        time.sleep(pause_seconds)

    return driver.find_elements(By.XPATH, CARD_XPATH)

def parse_card(card_el, search_term, fuel_type):
    raw = card_el.text
    cleaned = STAR_JUNK.sub('', raw)
    lines = [l.strip() for l in cleaned.splitlines() if l.strip()]
    age_match = AGE_RE.search(cleaned)
    price_age = age_match.group(1) if age_match else None
    if not lines:
        return {"Name": None, "Address": None, "City": None,
                "State": None, "Search": search_term, "FuelType": fuel_type,
                "CreditPrice": None, "PriceAge": price_age}
    # Handle co-branded names like "Shell\n& Sinclair"
    name = lines[0]
    idx = 1
    while idx < len(lines) and lines[idx].startswith('&'):
        name += ' ' + lines[idx]
        idx += 1
    # skip pure-digit review counts
    while idx < len(lines) and lines[idx].lstrip().lstrip('\u200b').isdigit():
        idx += 1
    address = lines[idx]   if idx < len(lines) else None
    city_st = lines[idx+1] if idx+1 < len(lines) else None
    price   = lines[idx+2] if idx+2 < len(lines) else None

    city, state = None, None
    if city_st:
        parts = city_st.rsplit(',', 1)
        city  = parts[0].strip() if len(parts) >= 1 else city_st
        state = parts[1].strip() if len(parts) == 2 else None

    if price and not price.startswith('$'):
        price = None

    return {
        "Name":        name,
        "Address":     address,
        "City":        city,
        "State":       state,
        "Search":      search_term,
        "FuelType":    fuel_type,
        "CreditPrice": price,
        "PriceAge":    price_age,
    }

try:
    for term in SEARCH_TERMS:
        encoded = quote_plus(term)
        print(f"\n=== {term} ===")

        for fuel_name, fuel_id in FUEL_TYPES.items():
            search_url = (
                f"https://www.gasbuddy.com/home?search={encoded}&fuel={fuel_id}&method=all&maxAge=0"
            )

            print(f"\n  -- {fuel_name} --")
            driver.get(search_url)
            try:
                wait.until(
                    EC.presence_of_element_located(
                        (By.XPATH, CARD_XPATH)
                    )
                )
            except TimeoutException:
                print("  Found 0 stations\n")
                continue
            time.sleep(2)

            cards = collect_station_cards(driver)

            print(f"  Found {len(cards)} stations\n")
            for card in cards:
                print(parse_card(card, term, fuel_name))

finally:
    driver.quit()
